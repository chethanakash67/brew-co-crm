CRM_URL=http://localhost:8000
PORT=3003
DELIVERY_MODE=real

# Email delivery via EmailJS
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_TEMPLATE_ID=your_emailjs_template_id
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_PRIVATE_KEY=your_emailjs_private_key

# SMS delivery via Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_SMS_FROM=+15551234567
# Or use a Messaging Service instead of TWILIO_SMS_FROM:
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WhatsApp delivery via Twilio
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Optional: public URL for provider callbacks, e.g. https://your-domain.com
# CHANNEL_PUBLIC_URL=

# Optional safe testing: send every campaign to your own inbox/phone first.
# TEST_RECIPIENT_EMAIL=you@example.com
# TEST_RECIPIENT_PHONE=+15558675310
